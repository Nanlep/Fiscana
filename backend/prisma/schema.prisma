// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  name            String
  role            String   @default("USER") // USER or ADMIN
  type            String   @default("INDIVIDUAL") // INDIVIDUAL or CORPORATE
  status          String   @default("ACTIVE") // ACTIVE or SUSPENDED
  companyName     String?
  kycStatus       String   @default("UNVERIFIED") // UNVERIFIED, PENDING, VERIFIED, REJECTED
  tier            String   @default("TIER_1") // TIER_1, TIER_2, TIER_3
  tin             String? // Tax Identification Number
  phone           String? // Phone number in E.164 format
  baniCustomerRef String? // Bani customer reference (e.g. MC-xxxxx)
  
  // Subscription
  subscriptionTier    String    @default("TRIAL")   // TRIAL, MONTHLY, ANNUAL, SANDBOX, EXPIRED
  subscriptionStatus  String    @default("ACTIVE")  // ACTIVE, PAST_DUE, CANCELLED, EXPIRED
  trialEndsAt         DateTime?                     // Set to now+14d on signup
  subscriptionEndsAt  DateTime?                     // Set after payment
  paymentReference    String?                       // Flutterwave transaction/subscription ID
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relationships
  transactions    Transaction[]
  invoices        Invoice[]
  assets          Asset[]
  liabilities     Liability[]
  budgets         Budget[]
  kycRequests     KYCRequest[]
  wallet          Wallet?
  smeApplications SMEApplication[]
  supportTickets  SupportTicket[]

  @@index([email])
  @@index([status])
  @@index([baniCustomerRef])
}

model PlatformConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model Transaction {
  id                   String   @id @default(uuid())
  userId               String
  date                 DateTime
  description          String
  payee                String
  amount               Float // Net amount (cash impact)
  grossAmount          Float? // Amount before WHT deduction
  currency             String // NGN or USD
  exchangeRateSnapshot Float?
  type                 String // INCOME or EXPENSE
  expenseCategory      String? // BUSINESS or PERSONAL
  category             String
  taxTag               String? // TAXABLE_INCOME, ALLOWABLE_EXPENSE, etc.
  tags                 String[] @default([])
  receiptUrl           String?
  taxDeductible        Boolean  @default(false)
  status               String   @default("CLEARED") // CLEARED, PENDING, VOID

  // Tax Details (stored as JSON)
  vatAmount  Float?
  whtAmount  Float?
  isRemitted Boolean @default(false)

  // Audit Log
  source     String // MANUAL, BANK_IMPORT, INVOICE_GENERATED, SYSTEM
  createdAt  DateTime  @default(now())
  createdBy  String
  modifiedAt DateTime?

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, type])
}

model Invoice {
  id                   String    @id @default(uuid())
  userId               String
  clientName           String
  clientEmail          String
  issueDate            DateTime
  dueDate              DateTime
  currency             String // NGN or USD
  subTotal             Float
  vatAmount            Float
  whtDeduction         Float
  totalAmount          Float
  amountPaid           Float     @default(0)
  status               String    @default("DRAFT") // DRAFT, SENT, PARTIALLY_PAID, PAID, OVERDUE
  paidDate             DateTime?
  paymentMethods       String[]  @default([])
  paymentBankName      String? // Receiving bank name
  paymentAccountNumber String? // Receiving account number
  paymentAccountName   String? // Receiving account name
  paymentWalletAddress String? // USDT wallet address
  paymentWalletNetwork String? // e.g. TRC-20
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relationships
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items    InvoiceItem[]
  payments PaymentRecord[]

  @@index([userId, status])
  @@index([userId, dueDate])
}

model InvoiceItem {
  id          String @id @default(uuid())
  invoiceId   String
  description String
  quantity    Int
  unitPrice   Float

  // Relationships
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model PaymentRecord {
  id        String   @id @default(uuid())
  invoiceId String
  date      DateTime
  amount    Float
  note      String?
  createdAt DateTime @default(now())

  // Relationships
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Asset {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  value       Float
  currency    String // NGN or USD
  type        String // CASH, BANK_ACCOUNT, CRYPTO, STOCKS, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model Liability {
  id          String    @id @default(uuid())
  userId      String
  name        String
  description String?
  amount      Float
  currency    String // NGN or USD
  type        String? // CREDIT_CARD, LOAN, MORTGAGE, etc.
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model Budget {
  id        String   @id @default(uuid())
  userId    String
  category  String
  limit     Float
  currency  String // NGN or USD
  type      String // BUSINESS or PERSONAL
  period    String   @default("MONTHLY")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, period])
  @@index([userId, period])
}

model KYCRequest {
  id         String    @id @default(uuid())
  userId     String
  userName   String
  userEmail  String
  bvn        String
  nin        String
  status     String    @default("PENDING") // PENDING, APPROVED, REJECTED
  date       DateTime  @default(now())
  reviewedAt DateTime?
  reviewedBy String?

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  balances WalletBalance[]

  @@index([userId])
}

model WalletBalance {
  id        String   @id @default(uuid())
  walletId  String
  currency  String // NGN, USD, GBP, EUR, KES, GHS, ZAR, USDT, BTC, ETH, etc.
  available Decimal  @default(0) @db.Decimal(18, 8)
  pending   Decimal  @default(0) @db.Decimal(18, 8)
  updatedAt DateTime @updatedAt

  // Relationships
  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@unique([walletId, currency])
  @@index([walletId])
}

model EmailVerification {
  id          String   @id @default(uuid())
  email       String
  code        String
  name        String
  password    String   // temporarily stored (hashed)
  type        String   @default("INDIVIDUAL")
  companyName String?
  expiresAt   DateTime
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([email, code])
}

model SMEApplication {
  id     String @id @default(uuid())
  userId String

  // ===== SECTION 1: BUSINESS INFORMATION =====
  businessName       String
  rcNumber           String?
  registeredWithCAC  Boolean  @default(false)
  businessType       String   // Sole Proprietorship / Partnership / Limited Company
  industrySector     String?
  businessAddress    String
  state              String?
  yearEstablished    String?
  numberOfEmployees  String?
  contactPersonName  String?
  contactPhone       String?
  contactEmail       String?

  // ===== SECTION 2: OWNER / DIRECTOR DETAILS =====
  ownerFullName            String?
  ownerDOB                 String?
  ownerGender              String?
  ownerBVN                 String?
  ownerNationalId          String?
  ownerResidentialAddress   String?
  ownerPercentageOwnership String?
  ownerPhone               String?
  ownerEmail               String?

  // ===== SECTION 3: BUSINESS OPERATIONS =====
  businessActivities    String?
  productsServices      String?
  majorCustomers        String?  // Retail / Corporate / Government / Export
  hasExistingContracts  Boolean  @default(false)
  monthlySalesRevenue   Float?
  monthlyExpenses       Float?
  monthlyProfitEstimate Float?

  // ===== SECTION 4: LOAN REQUEST DETAILS =====
  loanAmount               Float
  loanPurpose              String   // Working Capital / Asset Purchase / Expansion / Inventory / Invoice / Others
  loanTenorMonths          Int?     // months
  expectedMonthlyRepayment Float?
  hasPreviousLoan          Boolean  @default(false)
  previousLoanSource       String?
  previousLoanStatus       String?  // Active / Repaid / Defaulted

  // Legacy field kept for backward compat
  repaymentPeriod          Int      @default(12)

  // ===== SECTION 5: FINANCIAL RECORDS =====
  keepsFinancialRecords  Boolean  @default(false)
  hasBankStatements      Boolean  @default(false)
  hasFinancialStatements Boolean  @default(false)
  hasTIN                 Boolean  @default(false)
  primaryBankName        String?
  bankAccountNumber      String?

  // ===== SECTION 6: COLLATERAL / GUARANTEE =====
  hasCollateral            Boolean  @default(false)
  collateralType           String?  // Land/Property, Equipment, Inventory, None
  collateralEstimatedValue String?
  willingToProvideGuarantor Boolean @default(false)

  // Legacy fields kept for backward compat
  collateralDescription  String?
  guarantorName          String   @default("")
  guarantorPhone         String   @default("")
  guarantorEmail         String   @default("")
  guarantorRelationship  String   @default("")
  annualRevenue          Float    @default(0)

  // ===== SECTION 7: DOCUMENT UPLOADS =====
  cacDocumentUrl         String?
  validIdUrl             String?
  bankStatementUrl       String?
  utilityBillUrl         String?
  passportPhotoUrl       String?
  tinDocumentUrl         String?
  collateralDocumentUrl  String?
  taxClearanceUrl        String?

  // ===== DECLARATION =====
  applicantDeclarationName String?
  declarationDate          String?

  // ===== SCORING (Internal / Admin Only) =====
  preQualScore       Int?      // 0-9 checklist score
  revenueStrength    String?   // Low / Medium / High
  repaymentCapacity  String?   // Low / Medium / High
  creditHistory      String?   // Good / Fair / Poor
  documentationLevel String?   // Low / Medium / High
  preQualOutcome     String?   // Qualified / Conditionally Qualified / Not Qualified

  // ===== STATUS & ADMIN =====
  status     String    @default("PENDING") // PENDING, APPROVED, DECLINED
  adminNote  String?
  reviewedAt DateTime?
  reviewedBy String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status])
}

model SupportTicket {
  id        String   @id @default(uuid())
  userId    String
  subject   String
  status    String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages TicketMessage[]

  @@index([userId, status])
  @@index([status])
}

model TicketMessage {
  id         String   @id @default(uuid())
  ticketId   String
  senderId   String
  senderRole String   // USER or ADMIN
  senderName String
  message    String
  createdAt  DateTime @default(now())

  // Relationships
  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}
